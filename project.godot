; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="alchemy-jam-9"
run/main_scene="uid://3epgt3em7das"
config/features=PackedStringArray("4.7", "GL Compatibility")
boot_splash/use_filter=false
boot_splash/image="uid://djxwb1x66wd1e"
config/icon="res://icon.svg"
boot_splash/minimum_display_time=500

[aseprite]

animation/layers/only_include_visible_layers_by_default=true
import/cleanup/remove_json_file=false
import/import_plugin/default_automatic_importer="SpriteFrames"
import/cleanup/automatically_hide_sprites_not_in_animation=true
import/import_plugin/generate_bake_files=true

[audio]

buses/default_bus_layout="uid://fwlmqdadewg8"

[autoload]

ParticlePreloader="*uid://dqwj4eehf6s8c"
SceneManager="*uid://bsm3qbl5jgoll"
SignalBus="*uid://bb1vvd4p6stu2"
Audio="*uid://l03v58ywigen"
Util="*uid://q2l1ouwgvfu2"
GameOptions="*uid://ctuvyf5wi8yvk"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/AsepriteWizard/plugin.cfg", "res://addons/limbo_console/plugin.cfg", "res://addons/triggers/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray"
}

[gui]

theme/default_font_antialiasing=0
theme/default_font_hinting=0
theme/default_font_subpixel_positioning=0
theme/custom="uid://cssori3di6xfl"

[importer_defaults]

aseprite_wizard.plugin.spriteframes={
"animation/round_fps": true,
"layer/exclude_layers_pattern": "\\[H\\]",
"layer/only_visible_layers": true,
"sheet/frame_padding": 2,
"sheet/scale": 1,
"sheet/sheet_columns": 12,
"sheet/sheet_type": "packed"
}

